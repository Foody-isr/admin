# foodyadmin environment contract. Copy to .env.local and fill in.

# Foody API base URL (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Meta Embedded Signup (WhatsApp Tech Provider). These are browser-exposed by design —
# they appear in the FB.login() call. Twilio account credentials are NEVER exposed here.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_WA_CONFIG_ID=
NEXT_PUBLIC_TWILIO_SOLUTION_ID=
NEXT_PUBLIC_META_GRAPH_VERSION=v21.0
